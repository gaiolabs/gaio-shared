{
  "name": "dataos",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "backend": "cd apps/back && bun dev",
    "frontend": "cd apps/front && bun dev",
    "deploy": "rsync -r apps/back/* deploy && rsync -r apps/front/dist/* deploy/public",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "reset": "rsync -r node_modules && rsync -r bun.lockb && rsync -r package-lock.json && bun i"
  },
  "devDependencies": {
    "@gaio/eslint-config": "*",
    "@gaio/types": "*",
    "@gaio/typescript-config": "*",
    "@gaio/utils": "*",
    "@types/bun": "^1.1.6",
    "@types/lodash-es": "^4.17.12",
    "@types/nunjucks": "^3.2.6",
    "turbo": "^2.0.12"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.1.18",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "dayjs": "^1.11.11",
    "fastest-validator": "^1.18.0",
    "grid-layout-plus": "^1.0.5",
    "hono": "^4.5.4",
    "lodash-es": "^4.17.21",
    "mustache": "^4.2.0",
    "nunjucks": "^3.2.4",
    "ofetch": "^1.3.4",
    "typescript": "^5.5.3"
  }
}
